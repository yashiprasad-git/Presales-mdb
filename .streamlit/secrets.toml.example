# Copy to secrets.toml (do not commit secrets.toml).
# MDB updater + monitor dashboard only — no OpenAI key required.

DATABASE_URL = "postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
MONDAY_API_KEY = "your_monday_api_token"

# Optional — read org-restricted Google Sheets (service account JSON from IT):
# GOOGLE_APPLICATION_CREDENTIALS = "/absolute/path/to/service-account.json"
# Or paste the full JSON (multiline) as GOOGLE_SERVICE_ACCOUNT_JSON = '''{ "type": "service_account", ... }'''
#
# If IT enabled domain-wide delegation, act as a team user:
# GOOGLE_IMPERSONATE_USER = "program@silverpush.co"
